# The frontend talks to /api in both local dev and Vercel deploys.
VITE_API_BASE_URL=/api
VITE_API_BASE_PATH=/api

# Local Vite development proxies /api to the Laravel dev server.
# Start it with: npm run dev:api
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# On Vercel, set BACKEND_API_BASE_URL to your hosted backend API root.
# Example: https://your-backend-domain.com/api
VITE_FRONTEND_TEST_MODE=false
