<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews
    </IfModule>

    RewriteEngine On
    DirectoryIndex index.php

    # Public uploads are stored by Laravel inside backend/public/uploads.
    RewriteRule ^uploads/(.*)$ backend/public/uploads/$1 [L,NC]

    # Send API requests to Laravel while keeping /api/... as the request URI.
    RewriteRule ^api(?:/(.*))?$ backend/public/index.php [L,QSA,NC]

    # Frontend build files live in /app, but the SPA still references a few root-style asset paths.
    RewriteRule ^assets/(.*)$ app/assets/$1 [L,NC]
    RewriteRule ^models/(.*)$ app/models/$1 [L,NC]
    RewriteRule ^pwa-icons/(.*)$ app/pwa-icons/$1 [L,NC]
    RewriteRule ^manifest\.webmanifest$ app/manifest.webmanifest [L,NC]
    RewriteRule ^sw\.js$ app/sw.js [L,NC]
    RewriteRule ^ninofficialcheck-logo\.svg$ app/ninofficialcheck-logo.svg [L,NC]
    RewriteRule ^idmeservices-logo\.svg$ app/idmeservices-logo.svg [L,NC]

    # Serve existing files/assets normally.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # SPA fallback served from the built frontend entrypoint in /app.
    RewriteRule ^ index.php [L]
</IfModule>
